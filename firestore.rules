rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      let data = getUserData();
      return isSignedIn() && (request.auth.token.email == 'spondycodedev@gmail.com' || data.role == 'superadmin');
    }
    
    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && (isSuperAdmin() || data.role == 'admin' || data.isAdmin == true);
    }

    // Members: Signed-in users can read; admins can create/update (superadmin only for roles)
    match /members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == memberId && request.resource.data.role == 'member');
      allow update: if (isAdmin() && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || isSuperAdmin()))
                    || (request.auth.uid == memberId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])); 
      allow delete: if isSuperAdmin();
    }

    // Songs: Signed-in users can read, admins can modify
    match /songs/{songId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Rehearsals: Signed-in users can read, admins can modify
    match /rehearsals/{rehearsalId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Settings: Signed-in users can read, admins can modify
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Lock down everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
